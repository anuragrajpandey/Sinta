<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>For Sinta Pandey 💕</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Cormorant:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Raleway:wght@200;300;400&display=swap" rel="stylesheet">

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;tap-highlight-color:transparent;-webkit-touch-callout:none;}

:root{
  --rose:      #d4436e;
  --rose-deep: #a02050;
  --rose-lt:   #f7c5d5;
  --blush:     #fdeef4;
  --gold:      #c9933a;
  --gold-lt:   #f0d28a;
  --gold-pale: #fdf3dc;
  --plum:      #7a2648;
  --plum-deep: #3d0f23;
  --lilac:     #d4a8d8;
  --cream:     #fff9f5;
  --text:      #2e0d1c;
  --text-mid:  #7a3558;
  --text-lt:   #b87898;
}

html{scroll-behavior:smooth;}

body{
  background:var(--cream);
  color:var(--text);
  font-family:'Raleway',sans-serif;
  font-weight:300;
  overflow-x:hidden;
  cursor:none;
}

/* ═══ CURSOR */
#cursor{
  position:fixed;z-index:9999;pointer-events:none;
  width:28px;height:28px;margin-left:-14px;margin-top:-14px;
  font-size:22px;line-height:1;display:flex;align-items:center;justify-content:center;
  transition:transform .15s ease;
}
#cursor-trail{
  position:fixed;z-index:9998;pointer-events:none;
  width:14px;height:14px;margin-left:-7px;margin-top:-7px;
  background:radial-gradient(circle,rgba(212,67,110,.55),transparent 70%);
  border-radius:50%;
  transition:left .12s ease,top .12s ease;
}
@media(pointer:coarse){#cursor,#cursor-trail{display:none;} body{cursor:auto;}}

/* ═══ CANVASES */
#bg-canvas,#spark-canvas{position:fixed;inset:0;pointer-events:none;}
#bg-canvas{z-index:0;}
#spark-canvas{z-index:2;}

/* ═══════════════════════════════ HERO */
.hero{
  position:relative;z-index:1;
  min-height:100svh;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  text-align:center;
  padding:3rem 1.5rem 5rem;
  overflow:hidden;
}

.hero-aurora{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 100% 80% at 20% 20%, rgba(255,192,210,.75) 0%,transparent 55%),
    radial-gradient(ellipse 70% 60% at 80% 10%,  rgba(240,210,255,.6)  0%,transparent 50%),
    radial-gradient(ellipse 80% 70% at 60% 90%,  rgba(255,200,220,.55) 0%,transparent 60%),
    radial-gradient(ellipse 60% 50% at 5%  75%,  rgba(220,170,240,.45) 0%,transparent 50%),
    linear-gradient(155deg,#fff0f6 0%,#fce8f5 35%,#f5e5ff 65%,#fff0e8 100%);
  animation:aurora 12s ease-in-out infinite alternate;
}
@keyframes aurora{
  0%  {filter:hue-rotate(0deg)  brightness(1);}
  50% {filter:hue-rotate(8deg)  brightness(1.04);}
  100%{filter:hue-rotate(-6deg) brightness(.97);}
}
.hero-aurora::after{
  content:'';position:absolute;inset:0;
  background-image:radial-gradient(rgba(212,67,110,.1) 1px,transparent 1px);
  background-size:28px 28px;
}

.hero-eyebrow{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:clamp(.7rem,2.5vw,.9rem);
  letter-spacing:.28em;text-transform:uppercase;
  color:var(--text-mid);
  margin-bottom:1.4rem;
  opacity:0;animation:riseIn .9s .3s forwards;
  position:relative;
}
.hero-eyebrow::before,.hero-eyebrow::after{content:'✦';margin:0 .7em;color:var(--gold);font-size:.7em;}

.name-wrap{position:relative;opacity:0;animation:riseIn 1s .55s forwards;}

.hero-name{
  font-family:'Alex Brush',cursive;
  font-size:clamp(5rem,20vw,11rem);
  line-height:1;
  color:var(--rose-deep);
  text-shadow:0 2px 0 rgba(160,32,80,.15),0 8px 40px rgba(212,67,110,.22),0 0 80px rgba(212,67,110,.1);
  position:relative;
}
.hero-name-glow{
  position:absolute;inset:0;
  font-family:'Alex Brush',cursive;
  font-size:clamp(5rem,20vw,11rem);
  line-height:1;color:transparent;
  -webkit-text-stroke:1px rgba(212,67,110,.15);
  filter:blur(18px);pointer-events:none;
  animation:glowPulse 3s ease-in-out infinite;
}
@keyframes glowPulse{0%,100%{opacity:.5;}50%{opacity:1;}}

.hero-tagline{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:clamp(1.05rem,4vw,1.55rem);
  color:var(--plum);margin-top:.9rem;letter-spacing:.04em;
  opacity:0;animation:riseIn .9s .85s forwards;
}

.hearts-row{
  display:flex;gap:.6rem;justify-content:center;margin-top:1.6rem;
  opacity:0;animation:riseIn .9s 1.1s forwards;
}
.hearts-row span{font-size:clamp(1.4rem,4vw,2rem);display:inline-block;animation:heartbeat 1.6s ease-in-out infinite;}
.hearts-row span:nth-child(2){animation-delay:.2s;font-size:clamp(1.8rem,6vw,2.8rem);}
.hearts-row span:nth-child(3){animation-delay:.4s;}

.scroll-cue{
  position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:.35rem;
  opacity:0;animation:riseIn .8s 1.7s forwards;
  color:var(--text-lt);font-size:.65rem;letter-spacing:.22em;text-transform:uppercase;
}
.scroll-cue .arrow{
  width:20px;height:20px;
  border-right:1.5px solid var(--rose-lt);border-bottom:1.5px solid var(--rose-lt);
  transform:rotate(45deg);animation:scrollBounce 1.8s ease-in-out infinite;
}

/* ═══ DIVIDER */
.divider{
  position:relative;z-index:1;
  display:flex;align-items:center;justify-content:center;gap:1.2rem;padding:1rem;
}
.divider::before,.divider::after{
  content:'';flex:1;height:1px;
  background:linear-gradient(90deg,transparent,rgba(212,67,110,.3),transparent);
}
.divider-icon{font-size:1.4rem;color:var(--gold);}

/* ═══════════════════════════════ LETTER */
.section{position:relative;z-index:1;}

.letter-section{
  padding:clamp(3rem,8vw,6rem) clamp(1.2rem,5vw,3rem);
  display:flex;justify-content:center;
  background:
    radial-gradient(ellipse 60% 50% at 90% 30%,rgba(255,192,215,.35),transparent 60%),
    radial-gradient(ellipse 50% 40% at 5% 70%,rgba(212,170,230,.3),transparent 55%),
    var(--cream);
}

.letter-paper{
  max-width:740px;width:100%;
  background:#fff;border-radius:0 0 2rem 2rem;
  position:relative;
  box-shadow:
    0 1px 0 #f0d0de,0 2px 0 #f5d8e4,0 3px 0 #f9e0eb,
    0 12px 60px rgba(180,50,90,.08),0 40px 80px rgba(180,50,90,.05);
  padding:clamp(2.2rem,6vw,4rem) clamp(1.8rem,5vw,3.5rem);
}
.letter-paper::before{
  content:'';position:absolute;top:0;left:0;right:0;height:6px;border-radius:2rem 2rem 0 0;
  background:linear-gradient(90deg,var(--rose-lt),var(--lilac),var(--gold-lt),var(--rose-lt));
  background-size:200% 100%;animation:shimmer 4s linear infinite;
}
@keyframes shimmer{to{background-position:200% 0;}}
.letter-paper::after{
  content:'\201C';position:absolute;top:-2.2rem;left:2rem;
  font-family:'Alex Brush',cursive;font-size:9rem;
  color:rgba(212,67,110,.1);line-height:1;pointer-events:none;
}

.letter-from{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:.82rem;letter-spacing:.2em;text-transform:uppercase;
  color:var(--rose);margin-bottom:1.2rem;
  display:flex;align-items:center;gap:.8rem;
}
.letter-from::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,rgba(212,67,110,.3),transparent);}

.letter-h{
  font-family:'Alex Brush',cursive;
  font-size:clamp(2.4rem,7vw,3.6rem);
  color:var(--rose-deep);line-height:1.2;margin-bottom:1.5rem;
}
.letter-body{
  font-family:'Cormorant',serif;
  font-size:clamp(1.05rem,3vw,1.22rem);
  line-height:2;color:var(--text);
}
.letter-body p+p{margin-top:1.1em;}
.letter-sig{
  margin-top:2.2rem;font-family:'Alex Brush',cursive;
  font-size:clamp(2rem,5.5vw,2.8rem);color:var(--rose-deep);text-align:right;
}
.wax-seal{
  width:64px;height:64px;border-radius:50%;
  background:radial-gradient(circle at 38% 35%,#e8607e,#a02050);
  box-shadow:0 4px 16px rgba(160,32,80,.35),inset 0 -2px 6px rgba(0,0,0,.2);
  display:flex;align-items:center;justify-content:center;
  font-size:1.8rem;margin-left:auto;margin-top:-1rem;position:relative;
  animation:sealWiggle 6s ease-in-out infinite;
}
.wax-seal::before{content:'';position:absolute;inset:3px;border-radius:50%;border:1.5px dashed rgba(255,255,255,.35);}
@keyframes sealWiggle{0%,100%{transform:rotate(-3deg);}50%{transform:rotate(3deg);}}

/* ═══════════════════════════════ NAME CHANGE */
.name-section{
  padding:clamp(4rem,10vw,8rem) clamp(1.2rem,5vw,3rem);
  text-align:center;position:relative;overflow:hidden;
  background:linear-gradient(160deg,#2e0d1c 0%,#5e1a38 45%,#2e0d1c 100%);
}
.name-section::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 50%,rgba(212,67,110,.22),transparent 65%),
    radial-gradient(ellipse 50% 40% at 15% 80%,rgba(201,147,58,.15),transparent 55%),
    radial-gradient(ellipse 40% 30% at 85% 20%,rgba(212,170,216,.15),transparent 50%);
}
.name-section::after{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(105deg,transparent 0,transparent 60px,rgba(255,255,255,.018) 60px,rgba(255,255,255,.018) 61px);
  pointer-events:none;
}

.ns-eyebrow{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:clamp(.75rem,2.5vw,.9rem);
  letter-spacing:.3em;text-transform:uppercase;
  color:var(--gold-lt);opacity:.8;margin-bottom:2rem;position:relative;
}
.ns-title{
  font-family:'Alex Brush',cursive;
  font-size:clamp(2rem,6vw,3.2rem);
  color:rgba(255,255,255,.85);margin-bottom:2.8rem;position:relative;
}

.name-transform{
  position:relative;display:flex;flex-direction:column;align-items:center;
  gap:1.4rem;margin:0 auto 3rem;max-width:580px;
}

.name-box{
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);
  border-radius:1.2rem;padding:1.4rem 2.5rem;backdrop-filter:blur(12px);
  width:100%;transition:transform .3s;
}
.name-box:hover{transform:scale(1.02);}
.name-label{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;
  color:rgba(255,255,255,.45);margin-bottom:.4rem;
}
.name-value{
  font-family:'Alex Brush',cursive;
  font-size:clamp(2rem,7vw,3.4rem);line-height:1.1;
}
.name-box.old .name-value{
  color:rgba(255,200,210,.6);
  text-decoration:line-through;text-decoration-color:rgba(212,67,110,.5);
}
.name-box.new{
  background:linear-gradient(135deg,rgba(212,67,110,.18),rgba(201,147,58,.15));
  border-color:rgba(240,210,138,.3);
  box-shadow:0 0 40px rgba(212,67,110,.15),0 0 80px rgba(201,147,58,.08);
}
.name-box.new .name-value{
  background:linear-gradient(135deg,#f0d28a,#e8a0b0,#f0d28a);
  background-size:200% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation:goldShimmer 3s linear infinite;
}
@keyframes goldShimmer{to{background-position:200% center;}}

.arrow-down{
  width:36px;height:36px;border-radius:50%;
  background:rgba(212,67,110,.25);border:1px solid rgba(212,67,110,.35);
  display:flex;align-items:center;justify-content:center;
  color:var(--rose-lt);font-size:1rem;
  animation:arrowPulse 2s ease-in-out infinite;
}
@keyframes arrowPulse{0%,100%{transform:translateY(0);opacity:.8;}50%{transform:translateY(4px);opacity:1;}}

.ns-poem{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:clamp(1rem,3.5vw,1.3rem);
  color:rgba(255,255,255,.75);line-height:1.9;
  max-width:480px;margin:0 auto;position:relative;
}
.ns-poem em{color:var(--gold-lt);font-style:normal;}

/* ═══════════════════════════════ REASONS */
.reasons-section{
  padding:clamp(4rem,9vw,7rem) clamp(1.2rem,5vw,3rem);
  position:relative;
  background:
    radial-gradient(ellipse 70% 50% at 80% 20%,rgba(255,192,215,.4),transparent 55%),
    radial-gradient(ellipse 60% 50% at 10% 80%,rgba(220,175,240,.35),transparent 55%),
    linear-gradient(180deg,#fef0f6 0%,#fdf5ff 100%);
}

.sec-head{text-align:center;margin-bottom:clamp(2.5rem,6vw,4.5rem);}
.sec-eyebrow{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:.82rem;letter-spacing:.25em;text-transform:uppercase;
  color:var(--text-mid);margin-bottom:.8rem;
}
.sec-title{
  font-family:'Alex Brush',cursive;
  font-size:clamp(2.8rem,10vw,5rem);color:var(--rose-deep);line-height:1.1;
}

.reasons-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,280px),1fr));
  gap:1.4rem;max-width:980px;margin:0 auto;
}

.r-card{
  background:#fff;border-radius:2rem;padding:2rem 1.7rem;
  position:relative;overflow:hidden;
  border:1px solid rgba(212,67,110,.09);
  box-shadow:0 4px 24px rgba(160,40,80,.07);
  transition:transform .35s cubic-bezier(.34,1.56,.64,1),box-shadow .35s ease;
}
.r-card::before{
  content:'';position:absolute;inset:0;border-radius:2rem;
  background:linear-gradient(135deg,rgba(253,238,244,.8),rgba(255,255,255,0));pointer-events:none;
}
.r-card::after{
  content:'';position:absolute;top:0;left:1.5rem;right:1.5rem;height:2px;border-radius:0 0 2px 2px;
  background:linear-gradient(90deg,var(--rose-lt),var(--gold-lt),var(--lilac));
}
.r-card:hover{transform:translateY(-8px) rotate(.5deg);box-shadow:0 20px 50px rgba(160,40,80,.14);}

.r-icon-wrap{
  width:52px;height:52px;border-radius:1rem;
  background:linear-gradient(135deg,var(--blush),#fff);
  border:1px solid rgba(212,67,110,.15);
  display:flex;align-items:center;justify-content:center;
  font-size:1.6rem;margin-bottom:1rem;
  box-shadow:0 2px 12px rgba(212,67,110,.1);
}
.r-title{
  font-family:'Cormorant',serif;font-weight:600;
  font-size:1.15rem;color:var(--rose-deep);margin-bottom:.5rem;
}
.r-desc{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:1rem;line-height:1.8;color:var(--text-mid);
}

/* ═══════════════════════════════ PROMISES */
.promises-section{
  padding:clamp(5rem,11vw,9rem) clamp(1.2rem,5vw,3rem);
  text-align:center;
  background:linear-gradient(145deg,#1a0810 0%,#4a1530 45%,#1a0810 100%);
  position:relative;overflow:hidden;
}
.promises-section::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 90% 60% at 50% 0%,rgba(212,67,110,.2),transparent 55%),
    radial-gradient(ellipse 60% 50% at 20% 90%,rgba(201,147,58,.12),transparent 50%);
}
.promises-section::after{
  content:'✦';position:absolute;bottom:-2rem;right:5%;
  font-size:18rem;color:rgba(255,255,255,.018);
  font-family:'Alex Brush',cursive;line-height:1;pointer-events:none;
}

.ps-eyebrow{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:.82rem;letter-spacing:.28em;text-transform:uppercase;
  color:rgba(240,210,138,.6);margin-bottom:1rem;position:relative;
}
.ps-title{
  font-family:'Alex Brush',cursive;
  font-size:clamp(3rem,11vw,6rem);
  color:#fff;text-shadow:0 0 80px rgba(212,67,110,.45);
  margin-bottom:3rem;position:relative;line-height:1.05;
}

.promise-items{
  display:flex;flex-direction:column;gap:0;
  max-width:600px;margin:0 auto 3rem;position:relative;
}
.promise-items::before{
  content:'';position:absolute;left:22px;top:12px;bottom:12px;width:1px;
  background:linear-gradient(180deg,transparent,rgba(212,67,110,.5) 20%,rgba(201,147,58,.5) 80%,transparent);
}

.p-item{
  display:flex;align-items:flex-start;gap:1.2rem;
  padding:1.1rem 0;border-bottom:1px solid rgba(255,255,255,.05);
  text-align:left;transition:transform .3s;
}
.p-item:last-child{border-bottom:none;}
.p-item:hover{transform:translateX(6px);}

.p-num{
  width:44px;height:44px;border-radius:50%;flex-shrink:0;
  background:radial-gradient(circle at 35% 35%,rgba(212,67,110,.4),rgba(201,147,58,.2));
  border:1px solid rgba(212,67,110,.4);
  display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant',serif;font-style:italic;
  color:var(--gold-lt);font-size:.95rem;
}
.p-text{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:clamp(1rem,3.2vw,1.18rem);
  color:rgba(255,255,255,.82);line-height:1.7;padding-top:.35rem;
}
.ps-closing{
  font-family:'Alex Brush',cursive;
  font-size:clamp(1.8rem,6vw,2.8rem);
  color:var(--gold-lt);position:relative;
  text-shadow:0 0 40px rgba(201,147,58,.4);
}

/* ═══════════════════════════════ CLOSING */
.closing-section{
  padding:clamp(4rem,9vw,7rem) clamp(1.2rem,5vw,3rem);
  text-align:center;position:relative;
  background:
    radial-gradient(ellipse 80% 60% at 50% 50%,rgba(255,200,220,.5),transparent 65%),
    radial-gradient(ellipse 60% 50% at 10% 20%,rgba(220,180,240,.4),transparent 55%),
    radial-gradient(ellipse 50% 40% at 90% 80%,rgba(255,215,170,.35),transparent 50%),
    var(--cream);
}
.closing-section::before{
  content:'';position:absolute;inset:0;
  background:url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 2 L22 8 L28 8 L23 12 L25 18 L20 14 L15 18 L17 12 L12 8 L18 8 Z' fill='rgba(212,67,110,0.04)'/%3E%3C/svg%3E") repeat;
  pointer-events:none;
}

.forever-ring{
  width:clamp(160px,40vw,220px);height:clamp(160px,40vw,220px);
  border-radius:50%;
  background:conic-gradient(from 0deg,var(--rose-lt),var(--lilac),var(--gold-lt),var(--rose-lt));
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 2.5rem;position:relative;
  animation:spinSlow 20s linear infinite;
  box-shadow:0 0 60px rgba(212,67,110,.18);
}
@keyframes spinSlow{to{transform:rotate(360deg);}}

.forever-ring-inner{
  width:calc(100% - 8px);height:calc(100% - 8px);border-radius:50%;
  background:var(--cream);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  animation:spinSlow 20s linear infinite reverse;
}
.forever-ring-inner span:first-child{font-size:clamp(2.5rem,8vw,3.5rem);}
.forever-ring-inner span:last-child{
  font-family:'Alex Brush',cursive;font-size:clamp(1rem,3.5vw,1.4rem);
  color:var(--rose-deep);margin-top:.2rem;
}

.closing-title{
  font-family:'Alex Brush',cursive;
  font-size:clamp(3rem,11vw,5.5rem);color:var(--rose-deep);
  line-height:1.1;margin-bottom:1rem;position:relative;
}
.closing-sub{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:clamp(1.05rem,3.5vw,1.3rem);
  color:var(--plum);line-height:1.85;max-width:480px;margin:0 auto 2.5rem;
}
.closing-tag{
  display:inline-flex;align-items:center;gap:.6rem;
  background:#fff;border:1px solid rgba(212,67,110,.15);border-radius:50px;
  padding:.55rem 1.4rem;
  font-family:'Cormorant',serif;font-style:italic;
  font-size:.95rem;color:var(--rose);
  box-shadow:0 4px 20px rgba(212,67,110,.08);
}

/* ═══════════════════════════════ FOOTER */
footer{
  position:relative;z-index:1;padding:2.5rem 1.5rem;
  text-align:center;background:#fff;
  border-top:1px solid rgba(212,67,110,.08);
}
.footer-inner{display:flex;flex-direction:column;align-items:center;gap:.5rem;}
.footer-name{
  font-family:'Alex Brush',cursive;
  font-size:clamp(1.6rem,5vw,2.2rem);color:var(--rose-deep);
}
.footer-note{
  font-family:'Cormorant',serif;font-style:italic;
  font-size:.85rem;color:var(--text-lt);letter-spacing:.08em;
}

/* ═══ KEYFRAMES */
@keyframes riseIn{from{opacity:0;transform:translateY(28px);}to{opacity:1;transform:translateY(0);}}
@keyframes heartbeat{0%,100%{transform:scale(1);}14%{transform:scale(1.3);}28%{transform:scale(1);}42%{transform:scale(1.18);}}
@keyframes scrollBounce{0%,100%{transform:rotate(45deg) translateY(0);}50%{transform:rotate(45deg) translateY(5px);}}

/* ═══ SCROLL REVEAL */
.reveal{opacity:0;transform:translateY(36px);transition:opacity .85s ease,transform .85s ease;}
.reveal.up{opacity:1;transform:translateY(0);}
.d1{transition-delay:.08s;}.d2{transition-delay:.16s;}.d3{transition-delay:.24s;}
.d4{transition-delay:.32s;}.d5{transition-delay:.40s;}.d6{transition-delay:.48s;}

@media(max-width:520px){
  .name-box{padding:1.1rem 1.5rem;}
  .promise-items::before{left:18px;}
  .p-num{width:36px;height:36px;font-size:.8rem;}
}
</style>
</head>
<body>

<div id="cursor">💗</div>
<div id="cursor-trail"></div>
<canvas id="bg-canvas"></canvas>
<canvas id="spark-canvas"></canvas>

<!-- ══ HERO -->
<section class="hero">
  <div class="hero-aurora"></div>
  <p class="hero-eyebrow">a love made for eternity</p>
  <div class="name-wrap">
    <div class="hero-name-glow" aria-hidden="true">Sinta</div>
    <h1 class="hero-name">Sinta</h1>
  </div>
  <p class="hero-tagline">the one who took my whole heart, effortlessly</p>
  <div class="hearts-row"><span>🌸</span><span>💗</span><span>🌸</span></div>
  <div class="scroll-cue"><div class="arrow"></div><span>scroll</span></div>
</section>

<div class="divider"><span class="divider-icon">✦</span></div>

<!-- ══ LETTER -->
<section class="letter-section section">
  <div class="letter-paper reveal">
    <p class="letter-from">From Anurag · with every beat of his heart</p>
    <h2 class="letter-h">My dearest Sinta,</h2>
    <div class="letter-body">
      <p>There are things I cannot say out loud without my voice giving way — so I put them here, where the words can hold what I cannot. You walked into my life and quietly rearranged everything, and I am endlessly grateful that you did.</p>
      <p>You are the kind of person who makes ordinary days feel like something to remember. The way you laugh, the way you think, the way you care about everything around you — I notice all of it, and I fall for all of it, every single day without exception.</p>
      <p>Loving you is not something I chose once. It is something I choose again, every morning, every quiet evening, every ordinary moment in between. And I would choose it a thousand times over.</p>
    </div>
    <p class="letter-sig">— Anurag 🌹</p>
    <div class="wax-seal">💌</div>
  </div>
</section>

<div class="divider"><span class="divider-icon">🌸</span></div>

<!-- ══ NAME CHANGE -->
<section class="name-section section">
  <p class="ns-eyebrow reveal">a dream I hold close</p>
  <h2 class="ns-title reveal">The name I want for you</h2>

  <div class="name-transform reveal">
    <div class="name-box old">
      <p class="name-label">right now</p>
      <p class="name-value">Sinta Marpaung</p>
    </div>
    <div class="arrow-down">↓</div>
    <div class="name-box new">
      <p class="name-label">someday · forever</p>
      <p class="name-value">Sinta Pandey</p>
    </div>
  </div>

  <p class="ns-poem reveal">
    One day, I want the world to know you by a name<br>
    we carry <em>together</em> —<br>
    not because it replaces any part of you,<br>
    but because it means you chose <em>me</em>,<br>
    and I got to spend my whole life<br>
    being grateful for that.
  </p>
</section>

<div class="divider"><span class="divider-icon">💛</span></div>

<!-- ══ REASONS -->
<section class="reasons-section section">
  <div class="sec-head reveal">
    <p class="sec-eyebrow">written from memory & love</p>
    <h2 class="sec-title">Reasons I love you</h2>
  </div>
  <div class="reasons-grid">
    <div class="r-card reveal d1"><div class="r-icon-wrap">🌸</div><p class="r-title">Your smile</p><p class="r-desc">It could illuminate the darkest room — and it does, every single time without trying.</p></div>
    <div class="r-card reveal d2"><div class="r-icon-wrap">🌙</div><p class="r-title">Your warmth</p><p class="r-desc">Being near you feels like coming home — soft, safe, and exactly where I should be.</p></div>
    <div class="r-card reveal d3"><div class="r-icon-wrap">✨</div><p class="r-title">Your strength</p><p class="r-desc">You carry so much with so much grace — and I admire that more than I ever say.</p></div>
    <div class="r-card reveal d4"><div class="r-icon-wrap">🦋</div><p class="r-title">The way you laugh</p><p class="r-desc">Genuine, unfiltered, a little contagious — easily the most beautiful sound I know.</p></div>
    <div class="r-card reveal d5"><div class="r-icon-wrap">🌹</div><p class="r-title">Your kindness</p><p class="r-desc">You make the people around you feel truly seen — that is rare, and it is beautiful.</p></div>
    <div class="r-card reveal d6"><div class="r-icon-wrap">💫</div><p class="r-title">All of you</p><p class="r-desc">Every quirk, every mood, every quiet moment — every part of you, I love completely.</p></div>
  </div>
</section>

<div class="divider"><span class="divider-icon">✦</span></div>

<!-- ══ PROMISES -->
<section class="promises-section section">
  <p class="ps-eyebrow reveal">sworn on every star</p>
  <h2 class="ps-title reveal">My promises to you</h2>
  <div class="promise-items">
    <div class="p-item reveal d1"><div class="p-num">i</div><p class="p-text">To choose you — every single day, without hesitation and without exception.</p></div>
    <div class="p-item reveal d2"><div class="p-num">ii</div><p class="p-text">To celebrate you when you shine, and hold you close when the world feels heavy.</p></div>
    <div class="p-item reveal d3"><div class="p-num">iii</div><p class="p-text">To make you laugh as often and as loudly as possible — always.</p></div>
    <div class="p-item reveal d4"><div class="p-num">iv</div><p class="p-text">To be the person you can always, without any doubt, count on.</p></div>
    <div class="p-item reveal d5"><div class="p-num">v</div><p class="p-text">To love you more tomorrow than I do right now — and I already love you so much.</p></div>
  </div>
  <p class="ps-closing reveal">Forever yours — Anurag 💛</p>
</section>

<!-- ══ CLOSING -->
<section class="closing-section section">
  <div class="forever-ring reveal">
    <div class="forever-ring-inner">
      <span>💗</span><span>always</span>
    </div>
  </div>
  <h2 class="closing-title reveal">You & me,<br>always</h2>
  <p class="closing-sub reveal">In every version of this life, and every life after — I would find you, I would know you, and I would love you all over again.</p>
  <div class="closing-tag reveal"><span>💌</span><span>Anurag loves Sinta Pandey</span><span>💌</span></div>
</section>

<!-- ══ FOOTER -->
<footer>
  <div class="footer-inner">
    <p class="footer-name">Sinta Pandey 💕</p>
    <p class="footer-note">made with love by Anurag · forever & always</p>
  </div>
</footer>

<script>
/* ── CURSOR */
const cur=document.getElementById('cursor');
const trail=document.getElementById('cursor-trail');
let mx=0,my=0,tx=0,ty=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cur.style.left=mx+'px';cur.style.top=my+'px';
});
setInterval(()=>{
  tx+=(mx-tx)*.18;ty+=(my-ty)*.18;
  trail.style.left=tx+'px';trail.style.top=ty+'px';
},16);

/* ── PETAL / HEART BG CANVAS */
const bgC=document.getElementById('bg-canvas');
const bgX=bgC.getContext('2d');
function resizeBg(){bgC.width=innerWidth;bgC.height=innerHeight;}
resizeBg();window.addEventListener('resize',resizeBg);

const PCOLS=['#f9c5d5','#f07aaa','#fce8f2','#e86090','#fbbdd8','#f0c8e0','#d8b4f8','#ffd6e7'];
class Petal{
  constructor(init=false){this.reset(init);}
  reset(init=false){
    this.x=Math.random()*bgC.width;
    this.y=init?Math.random()*bgC.height:-20;
    this.r=5+Math.random()*9;
    this.vy=.35+Math.random()*.7;
    this.vx=(Math.random()-.5)*.5;
    this.rot=Math.random()*Math.PI*2;
    this.rs=(Math.random()-.5)*.025;
    this.a=.45+Math.random()*.45;
    this.col=PCOLS[Math.random()*PCOLS.length|0];
    this.sw=Math.random()*Math.PI*2;
    this.sws=.006+Math.random()*.012;
    this.isHeart=Math.random()<.12;
  }
  tick(){
    this.sw+=this.sws;
    this.x+=this.vx+Math.sin(this.sw)*.8;
    this.y+=this.vy;this.rot+=this.rs;
    if(this.y>bgC.height+20)this.reset();
  }
  draw(){
    bgX.save();bgX.globalAlpha=this.a;
    bgX.translate(this.x,this.y);bgX.rotate(this.rot);
    if(this.isHeart){
      bgX.font=`${this.r*2.2}px serif`;
      bgX.textAlign='center';bgX.textBaseline='middle';
      bgX.fillText('💗',0,0);
    }else{
      bgX.fillStyle=this.col;
      bgX.beginPath();
      bgX.ellipse(0,-this.r*.4,this.r*.42,this.r*.72,0,0,Math.PI*2);
      bgX.fill();
    }
    bgX.restore();
  }
}
const petals=Array.from({length:45},()=>new Petal(true));
(function loop(){
  bgX.clearRect(0,0,bgC.width,bgC.height);
  petals.forEach(p=>{p.tick();p.draw();});
  requestAnimationFrame(loop);
})();

/* ── CLICK SPARKLES */
const spC=document.getElementById('spark-canvas');
const spX=spC.getContext('2d');
function resizeSp(){spC.width=innerWidth;spC.height=innerHeight;}
resizeSp();window.addEventListener('resize',resizeSp);
const sparks=[];
const SCOLS=['#f9c5d5','#f0d28a','#d8b4f8','#e86090','#fff'];
class Spark{
  constructor(x,y){
    this.x=x;this.y=y;this.life=1;
    const a=Math.random()*Math.PI*2;
    const s=2+Math.random()*5;
    this.vx=Math.cos(a)*s;this.vy=Math.sin(a)*s-2;
    this.r=2+Math.random()*4;
    this.col=SCOLS[Math.random()*SCOLS.length|0];
    this.decay=.025+Math.random()*.035;
  }
  tick(){this.x+=this.vx;this.y+=this.vy;this.vy+=.18;this.life-=this.decay;}
  draw(){
    spX.save();spX.globalAlpha=this.life*.9;
    spX.fillStyle=this.col;
    spX.beginPath();spX.arc(this.x,this.y,this.r*this.life,0,Math.PI*2);
    spX.fill();spX.restore();
  }
}
document.addEventListener('click',e=>{for(let i=0;i<18;i++)sparks.push(new Spark(e.clientX,e.clientY));});
document.addEventListener('touchstart',e=>{
  const t=e.touches[0];
  for(let i=0;i<14;i++)sparks.push(new Spark(t.clientX,t.clientY));
},{passive:true});
(function sloop(){
  spX.clearRect(0,0,spC.width,spC.height);
  for(let i=sparks.length-1;i>=0;i--){
    sparks[i].tick();sparks[i].draw();
    if(sparks[i].life<=0)sparks.splice(i,1);
  }
  requestAnimationFrame(sloop);
})();

/* ── SCROLL REVEAL */
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('up');});
},{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
</script>
</body>
</html>